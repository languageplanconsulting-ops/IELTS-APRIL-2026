  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:api": "node server/index.mjs",
    "build": "tsc -b && vite build",
    "start": "node server/index.mjs",
    "lint": "eslint .",
